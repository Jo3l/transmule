# ─── TransMule — Environment Variables ────────────────────────────────────────
# Copy this file to .env and adjust the values.
#   cp .env.example .env

# ── User / group IDs (match your host user to avoid permission issues) ───────
PUID=1000
PGID=1000
TZ=Europe/Madrid

# ── Download directories (host paths mounted into containers) ────────────────
DOWNLOAD_DIR=./downloads
INCOMPLETE_DIR=./incomplete

# ── aMule ─────────────────────────────────────────────────────────────────────
# Password for aMule's EC (External Connector) interface — used by the
# middleware to talk to amuled over its binary protocol on port 4712.
AMULE_GUI_PASSWORD=hLETKciXJlnMAN0Z

# Password for aMule's built-in web UI (port 4711). Can be different from above.
AMULE_WEBUI_PASSWORD=hLETKciXJlnMAN0Z

# Host ports for aMule P2P traffic (change if defaults conflict)
AMULE_ED2K_TCP_PORT=4662
AMULE_ED2K_UDP_PORT=4672
AMULE_KAD_UDP_PORT=4665

# ── Transmission ──────────────────────────────────────────────────────────────
# Leave blank for no auth on the Transmission RPC endpoint.
TRANSMISSION_USER=
TRANSMISSION_PASS=

# Host port for Transmission peer traffic (change if default conflicts)
TRANSMISSION_PEER_PORT=51413

# ── Middleware ────────────────────────────────────────────────────────────────
# Host directory for the middleware SQLite database (users, config).
# Bind-mounted so data survives container rebuilds and volume prunes.
DATA_DIR=./data

# Random secret for signing JWT tokens. Change this!
JWT_SECRET=change-me-to-a-random-string

# ── pyLoad ───────────────────────────────────────────────────────────────────
# Credentials for pyLoad NG's web interface (used by the middleware to
# authenticate against pyLoad's HTTP API on port 8000).
# Default credentials set by linuxserver/pyload-ng are pyload / pyload.
# Change them via the pyLoad web UI and update these values to match.
PYLOAD_USER=pyload
PYLOAD_PASSWORD=pyload

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the middleware API.
# If the Docker host is accessed at http://myserver:3000, keep the default.
# Behind a reverse proxy with a sub-path, set e.g. https://myserver/api
API_BASE_URL=http://localhost:3000
