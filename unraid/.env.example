# ─── TransMule — Unraid Environment Variables ─────────────────────────────────
# Copy this file to .env alongside docker-compose.yml:
#   /boot/config/plugins/compose.manager/projects/transmule/.env

# ── User / group IDs ──────────────────────────────────────────────────────────
# Unraid defaults: nobody=99, users=100
PUID=99
PGID=100
TZ=UTC

# ── Paths ─────────────────────────────────────────────────────────────────────
# All containers share the same download / incomplete dirs.
APPDATA_DIR=/mnt/user/appdata/transmule
DOWNLOAD_DIR=/mnt/user/downloads/transmule
INCOMPLETE_DIR=/mnt/user/incomplete/transmule

# ── aMule ─────────────────────────────────────────────────────────────────────
# Password for aMule's EC interface. Change this!
AMULE_GUI_PASSWORD=changeme

# aMule P2P ports (change if they conflict with other containers)
AMULE_ED2K_TCP_PORT=4662
AMULE_ED2K_UDP_PORT=4672
AMULE_KAD_UDP_PORT=4665

# ── Transmission ──────────────────────────────────────────────────────────────
# Leave blank for no authentication on the Transmission RPC endpoint.
TRANSMISSION_USER=
TRANSMISSION_PASS=

# Transmission peer port
TRANSMISSION_PEER_PORT=51413

# ── pyLoad ────────────────────────────────────────────────────────────────────
PYLOAD_USER=pyload
PYLOAD_PASSWORD=pyload

# ── Middleware ────────────────────────────────────────────────────────────────
# Random secret for signing JWT tokens. Change this!
JWT_SECRET=change-me-to-a-long-random-string

# ── App container ─────────────────────────────────────────────────────────────
# Port the web UI (and proxied API) is exposed on.
# The Nuxt SPA and Nitro API are served from the same container on this port.
APP_PORT=3001
