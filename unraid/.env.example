# ─── TransMule — Unraid Environment Variables ─────────────────────────────────
# Copy this file to .env alongside docker-compose.yml:
#   /boot/config/plugins/compose.manager/projects/transmule/.env

# ── User / group IDs ──────────────────────────────────────────────────────────
# Unraid defaults: nobody=99, users=100
PUID=99
PGID=100
TZ=UTC

# ── Optional image overrides ──────────────────────────────────────────────────
# ghcr.io/jo3l/transmule publishes multi-arch manifests (amd64 + arm64).
TRANSMULE_APP_IMAGE=ghcr.io/jo3l/transmule:latest
AMULE_IMAGE=ngosang/amule:latest
TRANSMISSION_IMAGE=lscr.io/linuxserver/transmission:latest
PYLOAD_IMAGE=lscr.io/linuxserver/pyload-ng:latest

# ── Paths ─────────────────────────────────────────────────────────────────────
APPDATA_DIR=/mnt/user/appdata/transmule
DOWNLOAD_DIR=/mnt/user/downloads
# aMule uses this for in-progress downloads (/temp inside the container).
# Transmission uses the container's /tmp — no host mapping needed.
INCOMPLETE_DIR=/mnt/user/incomplete

# ── aMule ─────────────────────────────────────────────────────────────────────
# Password for aMule's EC interface.
# Run setup.sh to auto-generate a random value, or set it manually.
AMULE_GUI_PASSWORD=changeme

# aMule P2P ports (change if they conflict with other containers)
AMULE_ED2K_TCP_PORT=16881
AMULE_ED2K_UDP_PORT=16882
AMULE_KAD_UDP_PORT=16883

# ── Transmission ──────────────────────────────────────────────────────────────
# Leave blank for no authentication on the Transmission RPC endpoint.
TRANSMISSION_USER=
TRANSMISSION_PASS=

# Transmission peer port
TRANSMISSION_PEER_PORT=16884

# ── pyLoad ────────────────────────────────────────────────────────────────────
PYLOAD_USER=pyload
PYLOAD_PASSWORD=pyload

# ── Middleware ────────────────────────────────────────────────────────────────
# Random secret for signing JWT tokens.
# Run setup.sh to auto-generate this, or set it manually.
# If left blank, the app container generates and persists one automatically.
JWT_SECRET=change-me-to-a-long-random-string

# ── App container ─────────────────────────────────────────────────────────────
# Port the web UI is exposed on.
FRONTEND_PORT=3001
